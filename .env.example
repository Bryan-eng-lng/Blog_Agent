# Tavily — web search for the agent
TAVILY_API_KEY=your_tavily_api_key_here

# Groq — LLM inference (add more keys for rotation)
GROQ_KEY_1=your_groq_key_1_here
GROQ_KEY_2=your_groq_key_2_here

# Cerebras — faster LLM inference (optional, falls back to Groq)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# LangSmith — tracing and observability (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=blog-agent
